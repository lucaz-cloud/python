s=input("Enter your Password:")
up=0
sm=0
dg=0
sp=0
if (len(s))>1:
    for i in s:
        if i.isupper():
            up=up+1
        elif i.islower():
            sm=sm+1
        elif i.isdigit():
            dg=dg+1
        else:
            sp=sp+1
    if dg>0 and up>0 and sm>0 and sp>0:
        print("STRONG")
    else:
        print("WEAK")
else:
    print("PATHETIC")
