class Node:
    def __init__(self,data):
        self.data=data
        self.next=None
        
class linkedlist:
    def __init__(self):
        self.head=None
        
    def insert(self,data):
        newnode=Node(data)
        if self.head==None:
            self.head=newnode
        else:
            temp=self.head
            while(temp.next!=None):
                temp=temp.next
            temp.next=newnode
    
    def display(self):
        temp=self.head
        while(temp!=None):
            print(temp.data,end='-->')
            temp=temp.next
    


obj=linkedlist()
obj.insert(10)
obj.insert(20)
obj.insert(30)
obj.insert(40)
obj.display()
