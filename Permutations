class Solution(object):
    def backtrack(self, nums, curr, res):
        if len(curr) == len(nums):
            res.append(curr[:]) 
            return

        for i in nums:
            if i in curr:
                continue

            curr.append(i)
            self.backtrack(nums, curr, res)
            curr.pop()

    def permute(self, nums):
        res = []
        self.backtrack(nums, [], res)
        return res
