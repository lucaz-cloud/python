class Solution:
    def isValid(self, s: str) -> bool:
        stack=[]
        brackets={')':'(','}':'{',']':'['}
        for i in s:
            if(i in brackets.values()):
                stack.append(i)
            else:
                if(not stack or brackets[i]!=stack.pop()):
                    return False
        return len(stack)==0
