class Rect:
    def __init__(self):
        self.l=int(input("enter the length:"))
        self.b=int(input("enter the breath:"))
    
    def display(self):
        return self.l*self.b
    
n=int(input("enter any rectangles:"))
l=[]
for i in range (n):
    R=Rect()
    l.append(R)
for i in l:
    print("Area: ",i.display())
    
